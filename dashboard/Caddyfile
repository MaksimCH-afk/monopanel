# ============================================================================
#  Caddyfile — отдаёт статический дашборд (плитки) на :333.
#  Только статика; плитки сами строят URL приложений из текущего хоста + порта.
# ============================================================================

{
	admin off
	auto_https off
}

:333 {
	root * /srv/panel/dashboard
	file_server
	encode gzip

	# Дашборд можно встраивать сам в себя при желании.
	header Cache-Control "no-store"

	log {
		output stdout
		format console
	}
}
