# ─── Server ───────────────────────────────────────────────────────────────
PORT=3340

# ─── External API keys (server-side only; never exposed to the client) ──────
# Google Cloud Natural Language API key (method: analyzeEntities)
GOOGLE_NL_API_KEY=
# OpenAI API key (Chat Completions with Structured Outputs, strict json_schema)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.1

# ─── Mock mode ──────────────────────────────────────────────────────────────
# When "true", the app runs the full flow with deterministic fake NL/OpenAI
# responses so it works end-to-end without any API keys (for demo / dev / CI).
# Also auto-enabled per-service when the corresponding key is empty.
MOCK_MODE=false

# ─── Analysis thresholds (see TZ §8) ────────────────────────────────────────
MAX_COMPETITORS=10
# K = ceil(N * CONSENSUS_THRESHOLD_RATIO)
CONSENSUS_THRESHOLD_RATIO=0.5
# weak if target_salience < median_salience * (1 - WEAK_MARGIN)
WEAK_MARGIN=0.4
# entities with salience below this are treated as noise and dropped
SALIENCE_MIN=0.005
# Safeguard cap against the NL API's hard document-size limit (1M Unicode chars
# for analyzeEntities). Set high so realistic pages are never truncated.
MAX_DOC_CHARS=1000000
# competitor text length sent to the LLM for intent classification
LLM_TEXT_CHARS=4000

# ─── Phrase track: n-grams, density, language & stopwords (see TZ §5-§7) ─────
# highest n-gram level (n = 1..MAX; trigrams n=3 are always included)
NGRAM_MAX=4
# minimum occurrences in a document for an n-gram to count (drops hapax phrases)
NGRAM_MIN_COUNT=2
# cap of strongest phrases kept per n-level per document (4-grams explode otherwise)
NGRAM_TOP_N=100
# density floor for phrases — analogue of SALIENCE_MIN for entities
PHRASE_SALIENCE_MIN=0.0005
# phrase priority weights (no mid term) + specificity bonus per n above bigram
PHRASE_PRIORITY_W_COVERAGE=0.6
PHRASE_PRIORITY_W_GAP=0.4
PHRASE_SPECIFICITY_BONUS=0.05
PHRASE_PRIORITY_HIGH=0.66
PHRASE_PRIORITY_MEDIUM=0.4
# language detection (franc-min); off → language-agnostic mode
LANG_DETECT=true
# multilingual stopword filtering (stopwords-iso); off → keep all n-grams
STOPWORDS_ENABLED=true
# operator stop terms (brand/boilerplate), comma/space separated; also per-request
CUSTOM_STOPWORDS=

# ─── Priority scoring weights & bucket boundaries (see TZ §6.3) ──────────────
# score = W_COVERAGE*(coverage/N) + W_MID*has_mid + W_GAP*gap  (each in 0..1)
PRIORITY_W_COVERAGE=0.5
PRIORITY_W_MID=0.2
PRIORITY_W_GAP=0.3
# score >= HIGH -> high; >= MEDIUM -> medium; else low
PRIORITY_HIGH=0.66
PRIORITY_MEDIUM=0.4

# ─── Retry / backoff for external calls ─────────────────────────────────────
RETRY_MAX_ATTEMPTS=4
RETRY_BASE_MS=500
