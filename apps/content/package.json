{
  "name": "content-gap-analyzer",
  "version": "1.0.0",
  "description": "Content gap analyzer by entities and intent (MVP). Compares your page against competitors for one query and shows what is missing.",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node --env-file-if-exists=.env src/server.js",
    "dev": "node --env-file-if-exists=.env --watch src/server.js",
    "test": "node --test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "express": "^4.21.2",
    "franc-min": "^6.2.0",
    "stopwords-iso": "^1.1.0"
  }
}
