# Copy to .env and fill in. docker-compose reads .env automatically.

# SQLite database location (inside the container this lives on a mounted volume)
DATABASE_URL="file:/data/imagegen.db"

# Where generated images are written (mounted volume in Docker)
DATA_DIR="/data"

# Optional global OpenRouter key (fallback when a model has no personal key).
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=""

# Optional: shown to OpenRouter for attribution / rankings
OPENROUTER_APP_URL="http://localhost:3000"
OPENROUTER_APP_TITLE="ImageGen Dashboard"

# Per-model OpenRouter API keys — used by the seed on first run to pre-configure
# each model with its own key. Leave empty to set them later in the Settings tab.
OR_KEY_FLUX2_PRO=""
OR_KEY_FLUX2_MAX=""
OR_KEY_SEEDREAM=""
OR_KEY_GROK_IMAGINE=""
OR_KEY_RECRAFT=""
