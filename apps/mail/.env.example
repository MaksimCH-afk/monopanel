# ─── Server ───────────────────────────────────────────────────────────────
PORT=3338

# ─── Cloudflare D1 (server-side only; the token is never sent to the client) ─
# These can also be entered in the UI ("⚙ Настройки") and a runtime value there
# overrides these. Leave them empty to run in MOCK mode (demo mailboxes).
# Account ID (Cloudflare dashboard → right sidebar / any zone overview):
CF_ACCOUNT_ID=
# D1 database id (from `wrangler d1 create mail`):
CF_D1_DATABASE_ID=
# API token with D1 Read (and Edit if you delete/clean from the admin):
CF_API_TOKEN=

# Where UI-entered credentials are persisted (config.json). In Docker this is a
# mounted volume (/data/mail) so they survive rebuilds; unset → apps/mail/.data.
MAIL_DATA_DIR=

# Cosmetic: domain shown as a hint in the UI (e.g. acc37@<MAIL_DOMAIN>).
MAIL_DOMAIN=mydomain.com

# Default page size for the message list.
MAIL_LIST_LIMIT=50

# ─── Mock mode ──────────────────────────────────────────────────────────────
# "true" forces demo data even if credentials are set. Also auto-enabled when
# any of the three Cloudflare fields above is missing.
MOCK_MODE=false

# ─── Retry / backoff for D1 REST calls ──────────────────────────────────────
RETRY_MAX_ATTEMPTS=4
RETRY_BASE_MS=500
