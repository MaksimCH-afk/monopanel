# ─── Server ───────────────────────────────────────────────────────────────
PORT=3339

# ─── PacketStream account (server-side only; never exposed to the client) ────
# These can also be entered in the UI ("Сохранить доступ") — a runtime value
# overrides what is set here. The auth key is a secret: it is stored server-side,
# masked in the UI, and only ever embedded inside the assembled connection
# string (TZ §6). Without username + auth key the app runs, but strings use
# placeholders and the exit-IP test returns 409.
PS_USERNAME=
PS_AUTH_KEY=

# Where UI-entered settings + profiles are persisted (account.json / profiles.json).
# In Docker this is a mounted volume (/data/proxy) so they survive rebuilds;
# unset → apps/proxy/.data (gitignored).
PROXY_DATA_DIR=

# ─── Exit-IP test (TZ §5.4) ─────────────────────────────────────────────────
# IP-echo endpoint the backend hits THROUGH the proxy to report the exit-IP.
PROXY_TEST_URL=https://ifconfig.co/json
PROXY_TEST_TIMEOUT_MS=15000
# Rate-limit per profile for /api/proxy/test (TZ §6): min ms between calls.
PROXY_TEST_RATE_MS=1000

# ─── Reseller API (TZ §7, stage 2 — gated, granted after an application) ─────
# Bearer token; server-side only. Without it /api/reseller/* returns 409.
RESELLER_TOKEN=
# Base URL + paths come from the Postman collection issued with access — set
# them here once you have it (do not hard-code / guess the paths).
RESELLER_API_BASE=https://reseller.packetstream.io
RESELLER_BALANCE_PATH=/api/balance
RESELLER_SUBUSERS_PATH=/api/subusers
RESELLER_TIMEOUT_MS=15000
# When true, /api/reseller/* returns deterministic demo data without a token
# (mirrors their mock endpoint) so the UI works before access is granted.
RESELLER_MOCK=false
