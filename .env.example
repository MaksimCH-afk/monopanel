# ============================================================================
#  Единая панель — переменные окружения.  cp .env.example .env
#  .env закрыт в .gitignore и в репозиторий не попадает.
#  Всё опционально: без ключей приложения поднимутся, но часть функций не
#  заработает (генерация, GSC-вход и т.п.).
# ============================================================================

# --- LLM-ключи (общие: используют img и arc) ---
# OpenRouter — мультипровайдерный шлюз (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
# OpenAI — прямой доступ (https://platform.openai.com/api-keys); нужен seo-бэкенду и arc при LLM_PROVIDER=openai
OPENAI_API_KEY=

# --- arc (Web Archive Checker) ---
LLM_PROVIDER=openrouter
WHOIS_API_KEY=
MODEL_CLASSIFICATION=openai/gpt-4o-mini
MODEL_VERDICT=openai/gpt-4o-mini

# --- img (ImageGen) — необязательные ключи под конкретные модели ---
OR_KEY_FLUX2_PRO=
OR_KEY_FLUX2_MAX=

# --- seo (GSC Dashboard) — Auth0 (без них фронт поднимется, но вход не сработает) ---
# @auth0/nextjs-auth0 v4
AUTH0_SECRET=
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
APP_BASE_URL=http://localhost:3332
# Google Search Console — путь к client_secret.json для бэкенда (см. apps/seo)
# GSC_CLIENT_SECRET_PATH=/data/seo/client_secret.json

# --- cf (Cloudflare Panel) ---
# Токены Cloudflare хранятся в самой БД (cloudflare_panel.db), в .env не нужны.
# Логин/пароль по умолчанию на чистой БД: admin / admin (смените после входа).
