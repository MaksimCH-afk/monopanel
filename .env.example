# ============================================================================
#  Единая панель — пример переменных окружения
#  Скопируйте в .env и заполните нужными значениями:  cp .env.example .env
#  Файл .env закрыт в .gitignore и в репозиторий не попадает.
# ============================================================================

# --- Порты (по умолчанию совпадают с раскладкой из сводки проекта) ---
PORT_DASHBOARD=333
PORT_CF=3331
PORT_SEO=3332
PORT_ANK=3333
PORT_IMG=3334
PORT_ARC=3335
PORT_SKINS=3336

# --- ank / img: ключи генеративных моделей (по необходимости) ---
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# --- seo: Auth0 (без них фронт поднимется, но вход не сработает) ---
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
AUTH0_BASE_URL=
AUTH0_ISSUER_BASE_URL=

# --- seo: внутренний Flask-бэкенд (наружу не публикуется) ---
SEO_FLASK_PORT=5001

# --- Пути к данным внутри контейнера ---
# ank читает БД из DATA_DIR/app.db
ANK_DATA_DIR=/data/ank
# cf использует симлинк на /data/cf/cloudflare_panel.db
CF_DATA_DIR=/data/cf
