# ============================================================================
#  Единая панель — переменные окружения.  cp .env.example .env
#  .env закрыт в .gitignore и в репозиторий не попадает.
#  Всё опционально: без ключей приложения поднимутся, но часть функций не
#  заработает (генерация, GSC-вход и т.п.).
# ============================================================================

# --- LLM-ключи (общие: используют img и arc) ---
# OpenRouter — мультипровайдерный шлюз (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
# OpenAI — прямой доступ (https://platform.openai.com/api-keys); нужен seo-бэкенду и arc при LLM_PROVIDER=openai
OPENAI_API_KEY=

# --- arc (Web Archive Checker) ---
LLM_PROVIDER=openrouter
WHOIS_API_KEY=
MODEL_CLASSIFICATION=openai/gpt-4o-mini
MODEL_VERDICT=openai/gpt-4o-mini

# --- img (ImageGen) — необязательные ключи под конкретные модели ---
OR_KEY_FLUX2_PRO=
OR_KEY_FLUX2_MAX=

# --- seo (GSC Dashboard) ---
# В .env для seo секретов держать не нужно: и OpenAI-ключ, и учётные данные
# Google Search Console (client_secret.json) вводятся прямо в админке
# (seo → Настройки). Бэкенд сохраняет их в том /data/seo — класть/править файлы
# через терминал не требуется.
# (необязательно) нестандартный путь к сохранённому client_secret.json:
# GSC_CLIENT_SECRET_PATH=/data/seo/client_secret.json
# Адрес seo-бэкенда для ФРОНТА (запросы идут из браузера). По умолчанию
# http://localhost:5001 — подходит для локального запуска. Меняй, если фронт
# и бэкенд на разных хостах (напр. http://IP-сервера:5001).
# ВАЖНО: NEXT_PUBLIC_* «запекается» в бандл при СБОРКЕ. Значение подхватывается
# как build-arg в docker-compose, поэтому применяется только при пересборке:
#   docker compose up --build -d
# Для не-Docker запуска задайте эту переменную перед `npm run build` в apps/seo.
# NEXT_PUBLIC_SEO_API_URL=http://localhost:5001
# Уровень логов seo-бэкенда: INFO (по умолчанию) или DEBUG (максимально подробно).
# SEO_LOG_LEVEL=INFO
# Redis для seo (кэш/очереди). В docker-compose уже задан redis://redis:6379/0.
# Для не-Docker запуска: REDIS_URL=redis://localhost:6379/0 (без него кэш просто
# отключается — приложение работает, но без ускорения).
# REDIS_URL=redis://localhost:6379/0

# --- cf (Cloudflare Panel) ---
# Токены Cloudflare хранятся в самой БД (cloudflare_panel.db), в .env не нужны.
# Логин/пароль по умолчанию на чистой БД: admin / admin (смените после входа).

# --- content (Content Gap Analyzer) — сущности + интент vs конкуренты ---
# Оба ключа опциональны: пустой ключ → соответствующий сервис в mock-режиме,
# приложение всё равно поднимется на :3337 (см. apps/content/README.md).
# Google Cloud Natural Language API (метод analyzeEntities):
GOOGLE_NL_API_KEY=
# OpenAI берётся из общего OPENAI_API_KEY выше. Модель/режим — по желанию:
# OPENAI_MODEL=gpt-4o-mini
# MOCK_MODE=true   # принудительно весь поток на заглушках, без внешних вызовов

# --- mail (Cloudflare Email Catcher) — приём почты на *@домене через Worker + D1 ---
# Все три опциональны: без них приложение поднимется на :3338 в mock-режиме (демо-письма).
# Их также можно ввести прямо в UI (⚙ Настройки) — значение из UI сохраняется в
# томе /data/mail и переопределяет эти переменные. Токен нужен с правами D1 Read
# (и Edit, если удалять/чистить письма из админки). См. apps/mail/README.md.
CF_ACCOUNT_ID=
CF_D1_DATABASE_ID=
CF_API_TOKEN=
# Косметика: домен-подсказка в UI (напр. acc37@mydomain.com).
# MAIL_DOMAIN=mydomain.com
